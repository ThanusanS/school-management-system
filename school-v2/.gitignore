# ============================================================
# General .gitignore
# ============================================================

# ---- OS Files ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- Editor & IDE ----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace
.history/

# ---- Logs ----
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Dependencies ----
node_modules/
jspm_packages/
.pnp/
.pnp.js

# ---- Build Outputs ----
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
*.tsbuildinfo

# ---- Environment & Secrets ----
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# ---- Python ----
__pycache__/
*.py[cod]
*.pyo
.Python
venv/
.venv/
env/
*.egg-info/
.eggs/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# ---- Java ----
*.class
*.jar
*.war
*.ear
target/

# ---- C / C++ ----
*.o
*.a
*.so
*.out

# ---- Terraform ----
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars

# ---- Misc ----
*.bak
*.tmp
*.temp
*.swp
coverage/
.nyc_output/